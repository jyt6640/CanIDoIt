# 클라이언트에 노출되는 공개 설정값 (NEXT_PUBLIC_*).
# 실제 값은 .env.local 에 넣으세요 (git 커밋되지 않음).
# NEXT_PUBLIC_ 접두어 값은 번들에 인라인되므로 "비밀"이 아닙니다.

# 히어로 배경 비디오 URL. 비워두면 비디오 없이 배경만 렌더됩니다.
NEXT_PUBLIC_HERO_VIDEO_URL=

# 사이트 기준 URL (메타데이터 canonical, 공유 링크 생성 등)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 데이터베이스 (Prisma). 로컬은 SQLite, 프로덕션은 postgresql URL로 교체
DATABASE_URL="file:./dev.db"

# 카카오 공유 (선택). https://developers.kakao.com 앱의 JavaScript 키. 비우면 카카오 공유 버튼 숨김
NEXT_PUBLIC_KAKAO_JS_KEY=

# 히어로 비디오 poster 이미지 (선택)
NEXT_PUBLIC_HERO_POSTER_URL=

# Google Analytics 4 측정 ID (선택). 예: G-XXXXXXXXXX. 비우면 계측 비활성
NEXT_PUBLIC_GA_ID=
