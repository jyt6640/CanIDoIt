{
  "name": "can-i-do-it",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "node scripts/vercel-build.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm test",
    "test": "if node -e \"process.exit(process.allowedNodeEnvironmentFlags.has('--no-experimental-webstorage') ? 0 : 1)\"; then NODE_OPTIONS=--no-experimental-webstorage vitest run; else vitest run; fi",
    "test:watch": "if node -e \"process.exit(process.allowedNodeEnvironmentFlags.has('--no-experimental-webstorage') ? 0 : 1)\"; then NODE_OPTIONS=--no-experimental-webstorage vitest; else vitest; fi",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "db:setup": "prisma migrate deploy && prisma db seed",
    "deploy:migrate": "prisma migrate deploy",
    "db:dedupe": "node scripts/dedupe-warnings.mjs",
    "content:collect": "node scripts/collect-official-source.mjs",
    "content:draft": "node scripts/draft-content-from-snapshot.mjs"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/client": "^6.19.3",
    "eslint-config-next": "^16.2.10",
    "lucide-react": "^0.475.0",
    "next": "^16.2.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "eslint": "^9.39.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }
}
