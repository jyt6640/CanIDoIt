// Prisma schema — 해도돼? 여행 주의사항 데이터 모델
// 로컬 개발은 SQLite. 프로덕션 전환 시 datasource provider만 postgresql 로 교체.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WarningStatus {
  DRAFT
  REVIEWING
  VERIFIED
  STALE
  ARCHIVED
}

enum RiskLevel {
  CRITICAL
  HIGH
  MEDIUM
  INFO
}

model Country {
  id       String    @id @default(cuid())
  name     String    @unique // 표시명 (예: 일본)
  slug     String    @unique // URL 슬러그 (예: japan)
  cities   City[]
  warnings Warning[]
}

model City {
  id        String    @id @default(cuid())
  name      String // 표시명 (예: 오사카)
  slug      String // URL 슬러그 (예: osaka)
  country   Country   @relation(fields: [countryId], references: [id], onDelete: Cascade)
  countryId String
  warnings  Warning[]

  @@unique([countryId, slug])
}

model Warning {
  id            String   @id @default(cuid())
  key           String   @unique
  archived      Boolean  @default(false)
  status        WarningStatus @default(DRAFT)
  verifiedAt    DateTime?
  expiresAt     DateTime?
  reviewedBy    String?
  confidence    Int?
  title         String
  category      String
  risk          RiskLevel
  type          String
  range         String
  reason        String
  alternative   String
  diffFromKorea String?
  checkNeeded   String?
  locations     String[] @default([])
  keywords      String[] @default([])
  aliases       String[] @default([])
  legacyKeys    String[] @default([])
  order         Int      @default(0) // 노출 정렬 순서

  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  countryId String
  city      City?   @relation(fields: [cityId], references: [id], onDelete: Cascade)
  cityId    String? // null = 국가 공통

  sources Source[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([countryId])
  @@index([cityId])
  @@index([archived])
  @@index([status])
}

model OfficialSource {
  id            String   @id @default(cuid())
  countryCode   String
  agencyName    String
  url           String   @unique
  sourceType    String
  language      String   @default("en")
  enabled       Boolean  @default(true)
  lastFetchedAt DateTime?
  snapshots     SourceSnapshot[]
  drafts        ContentDraft[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([countryCode, enabled])
}

model SourceSnapshot {
  id            String   @id @default(cuid())
  source        OfficialSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId      String
  contentHash   String
  extractedText String
  changed       Boolean  @default(false)
  fetchedAt     DateTime @default(now())
  drafts        ContentDraft[]

  @@unique([sourceId, contentHash])
  @@index([sourceId, fetchedAt])
}

model ContentDraft {
  id          String   @id @default(cuid())
  source      OfficialSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId    String
  snapshot    SourceSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  snapshotId  String
  model       String
  payload     Json
  evidence    String
  status      WarningStatus @default(REVIEWING)
  createdAt   DateTime @default(now())
  reviewedAt  DateTime?

  @@index([status, createdAt])
}

// 출처 — "출처 기반" 신뢰 문구의 실체 (#3)
model Source {
  id        String    @id @default(cuid())
  title     String // 출처 설명 (예: 오사카시 노상금연 조례)
  url       String? // 공식 링크 (확인된 경우에만)
  checkedAt DateTime? // 최종 확인일
  warning   Warning   @relation(fields: [warningId], references: [id], onDelete: Cascade)
  warningId String
}

model SyncProfile {
  id            String   @id @default(cuid())
  token         String   @unique
  warningKeys   String[] @default([])
  notifyChanges Boolean  @default(false)
  lastCheckedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
